# Copy this file to .env for local development.
# Do not commit a real .env file with secrets.

APP_NAME="LLM RAG Document Assistant"
APP_VERSION="0.1.0"
LOG_LEVEL=INFO

DATA_DIR=data
CHROMA_DIR=data/chroma
CHROMA_COLLECTION=documents

CHUNK_SIZE=1000
CHUNK_OVERLAP=150
MAX_PREVIEW_CHARS=240

# OpenAI-compatible provider settings.
# Leave OPENAI_API_KEY empty to use the local mock providers.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
REQUEST_TIMEOUT_SECONDS=60

# Set to false only when OPENAI_API_KEY and compatible provider settings are configured.
USE_MOCK_LLM=true
USE_MOCK_EMBEDDINGS=true

